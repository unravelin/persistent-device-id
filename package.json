{
  "name": "persistent-device-id",
  "version": "1.0.0",
  "main": "persistent-device-id.js",
  "types": "persistent-device-id.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unravelin/persistent-device-id.git"
  },
  "author": "Ravelin (https://github.com/unravelin)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/unravelin/persistent-device-id/issues"
  },
  "homepage": "https://github.com/unravelin/persistent-device-id#readme",
  "scripts": {
    "clean": "rm -rf build dist releases; mkdir -p build dist",
    "build": "npm run ts:check && rollup --config",
    "build:watch": "npm run ts:check -- --watch & rollup --config --watch --no-watch.clearScreen",
    "postbuild": "rm -rf ./dist/types && replace-in-file 'import {' 'import type {' ./dist/*.d.ts",
    "dist": "cp README.md LICENSE .npmignore dist",
    "release": "run-s release:copy release:integrity release:integrity:verify release:tarball",
    "release:copy": "mkdir -p releases/persistent-device-id-$npm_package_version; set -x; cd build; for f in *.js*; do cp -- $f ../releases/persistent-device-id-$npm_package_version/`echo $f | sed s/^ravelin-/ravelin-$npm_package_version-/`; done",
    "release:integrity": "cd releases/persistent-device-id-$npm_package_version; shasum -a 384 *.js | sed s/^/sha384-/ > integrity",
    "release:integrity:verify": "cd releases/persistent-device-id-$npm_package_version; sed s/^sha384-// integrity | shasum -c",
    "release:tarball": "cd releases; tar -czf persistent-device-id-$npm_package_version.tar.gz persistent-device-id-$npm_package_version",
    "lint:ts": "eslint -f codeframe --max-warnings 0",
    "lint:prettier": "prettier --write --experimental-cli --log-level warn '**/*.{ts,js,mjs}'",
    "test": "karma start ./test-unit/karma.conf.js --single-run",
    "ts:check": "tsc --noEmit --skipLibCheck",
    "version": "run-s clean build dist release # (note: auto-executed by np)"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@ianvs/prettier-plugin-sort-imports": "4.7.0",
    "@rollup/plugin-commonjs": "29.0.0",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-replace": "6.0.3",
    "@rollup/plugin-terser": "0.4.4",
    "@rollup/plugin-typescript": "12.3.0",
    "chai": "4.5.0",
    "eslint": "9.39.2",
    "eslint-formatter-codeframe": "7.32.2",
    "globals": "17.0.0",
    "karma": "6.4.4",
    "karma-chai": "0.1.0",
    "karma-chrome-launcher": "3.2.0",
    "karma-mocha": "2.0.1",
    "mocha": "11.7.1",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.0",
    "replace-in-file": "8.4.0",
    "rollup": "4.57.0",
    "rollup-plugin-dts": "6.3.0",
    "rollup-plugin-generate-package-json": "3.2.0",
    "rollup-plugin-license": "3.6.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.53.1"
  },
  "mocha": {
    "timeout": 10000
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "trailingComma": "es5",
    "arrowParens": "avoid",
    "bracketSameLine": true,
    "importOrderTypeScriptVersion": "5.0.0",
    "importOrder": [
      "<BUILTIN_MODULES>",
      "<THIRD_PARTY_MODULES>",
      "^[.].+$",
      "^[.]$"
    ],
    "plugins": [
      "@ianvs/prettier-plugin-sort-imports"
    ]
  },
  "engines": {
    "node": ">=22.x"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "22.16.0"
    }
  },
  "volta": {
    "node": "22.16.0"
  }
}
